{
  "expo": {
    "name": "Consume lo Nuestro",
    "slug": "consume-lo-nuestro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a7a4a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "bo.gob.oruro.consumelonuestro",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para tomar fotos de tus productos.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para subir imágenes de productos.",
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para mostrarte productores cercanos.",
        "NSLocationAlwaysUsageDescription": "Usamos tu ubicación para mostrarte productores cercanos."
      }
    },
    "android": {
      "package": "bo.gob.oruro.consumelonuestro",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a7a4a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app accede a tus fotos para subir imágenes de productos.",
          "cameraPermission": "La app usa la cámara para tomar fotos de tus productos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Necesitamos tu ubicación para mostrarte productores cercanos en el mapa."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a7a4a"
        }
      ],
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser",
      "expo-font"
    ],
    "scheme": "consumelonuestro",
    "extra": {
      "supabaseUrl": "https://dlfnyfhjqofzkafzbwdt.supabase.co",
      "eas": {
        "projectId": "PONER-AQUI-EL-ID-DE-EAS-DESPUES-DE-eas-init"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
